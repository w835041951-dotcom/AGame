; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but the file format allows making changes to the project.

config_version=5

[application]

config/name="MineSweeper Roguelite"
config/description="A roguelite game where finding bombs damages the boss"
run/main_scene="res://scenes/game/Main.tscn"
config/features=PackedStringArray("4.2", "Forward Plus")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720

[autoload]

GameManager="*res://scripts/core/GameManager.gd"
GridManager="*res://scripts/core/GridManager.gd"
BombRegistry="*res://scripts/bombs/BombRegistry.gd"
BombEffect="*res://scripts/bombs/BombEffect.gd"
UpgradeManager="*res://scripts/core/UpgradeManager.gd"

[rendering]

renderer/rendering_method="forward_plus"
