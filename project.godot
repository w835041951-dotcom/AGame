; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="炸弹人勇闯100层地牢"
config/description="扫雷找炸弹，放置炸弹打Boss，勇闯100层地牢"
run/main_scene="res://scenes/game/Main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://scripts/core/GameManager.gd"
GridManager="*res://scripts/core/GridManager.gd"
BombRegistry="*res://scripts/bombs/BombRegistry.gd"
BossGrid="*res://scripts/boss/BossGrid.gd"
BombPlacer="*res://scripts/boss/BombPlacer.gd"
ExplosionCalc="*res://scripts/boss/ExplosionCalc.gd"
UpgradeManager="*res://scripts/core/UpgradeManager.gd"
AudioManager="*res://scenes/core/AudioManager.tscn"
LevelData="*res://scripts/core/LevelData.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
